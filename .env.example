# ML Insights Hub - Environment Variables Template
# Copy this file to .env and fill in your values

# ===================
# Server Configuration
# ===================
NODE_ENV=development
PORT=5000

# ===================
# Database (MongoDB)
# ===================
# For local development (non-Docker):
# MONGODB_URI=mongodb://localhost:27017/ml_insights

# For Docker (use these):
MONGO_ROOT_USER=admin
# REPLACE_ME before any non-local deployment. Startup will refuse to boot
# in production if this value still contains "REPLACE_ME" or "changeme".
MONGO_ROOT_PASSWORD=REPLACE_ME_WITH_A_STRONG_PASSWORD
MONGO_DB=ml_insights

# ===================
# Authentication
# ===================
# Generate a secure JWT secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Startup validation rejects this placeholder and any value under 64 chars.
JWT_SECRET=REPLACE_ME_RUN_generate-jwt-secret
JWT_EXPIRE=7d

# ===================
# Frontend
# ===================
FRONTEND_URL=http://localhost:3000
REACT_APP_API_URL=http://localhost:5000

# ===================
# Redis (Optional)
# ===================
# REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=REPLACE_ME_WITH_A_STRONG_REDIS_PASSWORD

# ===================
# Python Environment
# ===================
PYTHON_PATH=../venv/bin/python

# ===================
# File Uploads
# ===================
MAX_FILE_SIZE=10485760

# ===================
# AWS S3 (required in production)
# ===================
# Dataset uploads are streamed to S3; Dataset.file_path stores the S3 key.
AWS_S3_BUCKET=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ===================
# Logging (Optional)
# ===================
# Set to 'true' to enable file logging in development
ENABLE_FILE_LOGGING=false

# ===================
# Development Tools (Optional)
# ===================
# Skip authentication in development (SECURITY: Never use in production!)
# SKIP_AUTH=false

# Mongo Express (Docker dev only)
MONGO_EXPRESS_USER=admin
MONGO_EXPRESS_PASSWORD=pass

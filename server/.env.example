# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/ml-insights-hub

# JWT Authentication - CRITICAL SECURITY SETTING
# 🚨 NEVER use the placeholder below in production!
# 🔐 Generate secure secret: npm run generate-jwt-secret --update-env
# 📋 Verify security: npm run check-security
# 🛡️  Requirements: Minimum 64 hex characters (256+ bits entropy)
# 📝 Example generation: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=GENERATE_SECURE_SECRET_FOR_PRODUCTION_USE_CRYPTO_RANDOM_BYTES_64_HEX
JWT_EXPIRE=7d

# Python Environment
PYTHON_PATH=../venv/bin/python

# File Upload Configuration
MAX_FILE_SIZE=10485760

# AWS S3 (required in production — dataset uploads stream to S3)
AWS_S3_BUCKET=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# CORS Configuration (Production: Use specific domain)
FRONTEND_URL=http://localhost:3000

# ML Model Storage
MODEL_STORAGE_PATH=../models

# Security Settings (Production)
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100
# ENABLE_HELMET=true
# ENABLE_CORS_CREDENTIALS=false
